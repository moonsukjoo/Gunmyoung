rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isHRManager() {
      return isAuthenticated() && (
        (request.auth.token.email != null && (request.auth.token.email.lower() == "tjrwnfjqm1@gmail.com" || request.auth.token.email == "tjrwnfjqm1@gmail.com")) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['CEO', 'DIRECTOR', 'GENERAL_AFFAIRS', 'GENERAL_MANAGER', 'CLERK', 'SAFETY_MANAGER', 'TEAM_LEADER'] ||
          (
            'permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['admin', 'employee_mgmt', 'leave_mgmt', 'attendance_mgmt', 'notice_mgmt', 'redemption_mgmt', 'training_mgmt', 'accident_mgmt'])
          )
        ))
      );
    }

    function canManageLeave() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['leave_mgmt']));
    }

    function canManageCoupons() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['coupon_mgmt', 'redemption_mgmt', 'praise_coupon']));
    }

    function isSafetyManager() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SAFETY_MANAGER');
    }
    
    // Global Read/Write settings for core metadata
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isHRManager();
    }

    match /jobRoles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /positions/{posId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /users/{uid} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && (request.auth.uid == uid || isHRManager());
      allow update: if isAuthenticated() && (
        request.auth.uid == uid || 
        isHRManager() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kudosCount', 'monthlyKudosCount', 'kudosMonth']) && 
         (
           (request.resource.data.kudosMonth == resource.data.get('kudosMonth', '') && request.resource.data.monthlyKudosCount == (resource.data.get('monthlyKudosCount', 0) + 1)) ||
           (request.resource.data.kudosMonth != resource.data.get('kudosMonth', '') && request.resource.data.monthlyKudosCount == 1)
         )) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentAltitude', 'altitudeUpdatedAt', 'basePressure']))
      );
      allow delete: if isHRManager();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isOwner(request.resource.data.uid) || 
        isHRManager() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEAM_LEADER' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId == request.resource.data.departmentId)
      );
    }

    match /leaveRequests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageLeave());
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create, update: if isHRManager();
      allow delete: if isHRManager();
    }

    match /accidentCases/{caseId} {
      allow read: if isAuthenticated();
      allow create, update: if isSafetyManager();
      allow delete: if isSafetyManager();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated(); 
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if canManageCoupons();
    }

    match /redemptions/{redemptionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || canManageCoupons());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageCoupons());
    }

    match /redemptionRequests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageCoupons());
    }

    match /praiseCoupons/{couponId} {
       allow read: if isAuthenticated();
       allow write: if isAuthenticated();
    }

    match /praises/{praiseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.senderUid == request.auth.uid &&
                      request.resource.data.receiverUid != request.auth.uid;
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }

    match /trainings/{trainingId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /trainingResults/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || isHRManager());
    }

    match /lottoHistory/{historyId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated() && isOwner(request.resource.data.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isOwner(request.resource.data.uid) || 
        isHRManager() || 
        isOwner(request.resource.data.assignedToUid)
      );
    }

    match /userShipParts/{partId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated() && isOwner(request.resource.data.uid);
    }

    match /emergencyLogs/{logId} {
      allow read: if isAuthenticated() && (isHRManager() || isSafetyManager());
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid);
    }
    
    match /safetyScoreLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isHRManager() || isSafetyManager();
    }

    match /workLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (request.method == 'create' && isOwner(request.resource.data.uid)) ||
        (request.method == 'update' && (isOwner(resource.data.uid) || isHRManager())) ||
        isHRManager()
      );
    }

    match /evacuation/status {
      allow read: if isAuthenticated();
      allow write: if isSafetyManager();
    }

    match /evacuations/{evacuationId}/checkins/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(uid) || isSafetyManager());
    }

    // Default deny at the end
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
