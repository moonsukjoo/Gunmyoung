rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCoreAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "tjrwnfjqm1@gmail.com") ||
        (
          !isExcludedRole() && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['CEO', 'DIRECTOR', 'GENERAL_MANAGER'] ||
            (
              'permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['admin'])
            )
          )
        )
      );
    }

    function isHRManager() {
      return isAuthenticated() && !isExcludedRole() && (
        isCoreAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['GENERAL_AFFAIRS', 'CLERK', 'SAFETY_MANAGER', 'TEAM_LEADER'] ||
            (
              'permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions != null &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['employee_mgmt', 'leave_mgmt', 'attendance_mgmt', 'notice_mgmt', 'redemption_mgmt', 'training_mgmt', 'accident_mgmt'])
            )
          )
        )
      );
    }

    function canManageLeave() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['leave_mgmt']));
    }

    function canManageCoupons() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['coupon_mgmt', 'redemption_mgmt', 'praise_coupon']));
    }

    function isSafetyManager() {
      return isHRManager() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SAFETY_MANAGER');
    }

    function isRestrictedUser(data, email) {
      return (data == null && email != null && email.lower().matches('.*x66626.*')) ||
             (data != null && (
               data.get('employeeId', '').lower().matches('.*x66626.*') || 
               data.get('displayName', '').lower().matches('.*x66626.*') || 
               data.get('email', '').lower().matches('.*x66626.*') || 
               (email != null && email.lower().matches('.*x66626.*'))
             ));
    }

    function isExcludedRole() {
      let email = request.auth.token.get('email', '').lower();
      let name = request.auth.token.get('name', '').lower();
      return isAuthenticated() && 
             (email != "tjrwnfjqm1@gmail.com") &&
             (
               email.matches('.*x66626.*') || 
               name.matches('.*x66626.*') ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                isRestrictedUser(get(/databases/$(database)/documents/users/$(request.auth.uid)).data, email))
             );
    }
    
    // Core Collections Mapping
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /safetyScoreConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSafetyManager();
    }

    match /jobRoles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /positions/{posId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /users/{uid} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && (request.auth.uid == uid || isHRManager());
      allow update: if isAuthenticated() && (
        (isHRManager() && !isExcludedRole()) ||
        (request.auth.uid == uid && (
          // 1. Self-downgrade to restricted state
          (
            request.resource.data.employeeId == 'x66626' &&
            request.resource.data.role == 'EMPLOYEE' &&
            request.resource.data.position == '사원' 
          ) ||
          // 2. Safe fields update (always allowed for self)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'photoURL', 'position', 'birthDate', 'jobRole', 'lastLogin', 'fcmToken', 'elderlyMode', 'points', 'safetyScore', 'healthScore'])) ||
          // 3. Sensor/Feature specific updates
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentAltitude', 'altitudeUpdatedAt', 'basePressure', 'ghostGuardEnabled', 'lastMovementAt', 'isImmobile'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kudosCount', 'monthlyKudosCount', 'kudosMonth'])) ||
          // 4. General update for NON-restricted users
          (!isExcludedRole() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'employeeId', 'isActive']))
        ))
      );
      allow delete: if isHRManager() && !isExcludedRole();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isOwner(request.resource.data.uid) || 
        isHRManager() ||
        (getProfile().role == 'TEAM_LEADER' && getProfile().departmentId == request.resource.data.departmentId)
      );
    }

    match /leaveRequests/{requestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageLeave());
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isHRManager();
    }

    match /accidentCases/{caseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSafetyManager();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated(); 
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if canManageCoupons();
    }

    match /redemptions/{redemptionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || canManageCoupons());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageCoupons());
    }

    match /redemptionRequests/{requestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || canManageCoupons());
    }

    match /praiseCoupons/{couponId} {
       allow read: if isAuthenticated();
       allow write: if isAuthenticated();
    }

    match /rewardHistory/{historyId} {
      allow read: if isAuthenticated();
      allow write: if canManageCoupons();
    }

    match /praises/{praiseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.senderUid == request.auth.uid &&
                      request.resource.data.receiverUid != request.auth.uid;
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }

    match /trainings/{trainingId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /trainingResults/{resultId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow write: if isAuthenticated() && (isOwner(request.resource.data.uid) || isHRManager());
    }

    match /trainingRecords/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /lottoHistory/{historyId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated() && isOwner(request.resource.data.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isOwner(request.resource.data.uid) || 
        isHRManager() || 
        isOwner(request.resource.data.assignedToUid)
      );
    }

    match /userShipParts/{partId} {
      allow read: if isAuthenticated() && isOwner(resource.data.uid);
      allow write: if isAuthenticated() && isOwner(request.resource.data.uid);
    }

    match /emergencyLogs/{logId} {
      allow read: if isAuthenticated() && (isHRManager() || isSafetyManager());
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid);
    }
    
    match /safetyScoreLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isHRManager() || isSafetyManager();
    }

    match /workLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (request.method == 'create' && isOwner(request.resource.data.uid)) ||
        (request.method == 'update' && (isOwner(resource.data.uid) || isHRManager())) ||
        isHRManager()
      );
    }

    match /teamWorkLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isHRManager() || isOwner(resource.data.createdByUid));
    }

    match /personalWorkLogs/{logId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.uid) || 
        isHRManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['TEAM_LEADER', 'DIRECTOR']) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.position.matches('.*장.*'))
      );
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid);
      allow update: if isAuthenticated() && (
        isHRManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['TEAM_LEADER', 'DIRECTOR']) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.position.matches('.*장.*'))
      );
      allow delete: if isHRManager() || isOwner(resource.data.uid);
    }

    match /evacuation/status {
      allow read: if isAuthenticated();
      allow write: if (request.auth.token.email != null && request.auth.token.email.lower() == "tjrwnfjqm1@gmail.com") || 
                     isSafetyManager() || 
                     isCoreAdmin();
    }

    match /evacuations/{evacuationId} {
      allow read: if isAuthenticated(); // Allow everyone to see history
      allow write: if (request.auth.token.email != null && request.auth.token.email.lower() == "tjrwnfjqm1@gmail.com") || 
                     isSafetyManager() || 
                     isCoreAdmin();
      
      match /checkins/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isOwner(uid) || isSafetyManager() || isCoreAdmin());
      }
    }

    match /payslips/{payslipId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow write: if isHRManager();
    }

    match /lunchRequests/{requestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid);
      allow update: if isHRManager();
      allow delete: if isHRManager() || isOwner(resource.data.uid);
    }

    match /snackRequests/{requestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isHRManager());
      allow create: if isAuthenticated() && (
        isHRManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['TEAM_LEADER', 'DIRECTOR']) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.position.matches('.*장.*')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.position.matches('.*총무.*'))
      );
      allow update: if isHRManager();
      allow delete: if isHRManager() || isOwner(resource.data.uid);
    }

    match /beacons/{beaconId} {
      allow read: if isAuthenticated();
      allow write: if isSafetyManager();
    }

    match /workInstructionReports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isHRManager();
      allow update: if isAuthenticated() && (
        isHRManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile().departmentId == resource.data.teamId)
      );
      allow delete: if isHRManager();
    }

    match /beaconLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /adminNotifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isHRManager();
    }

    match /healthReports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isHRManager() || 
        (getProfile().get('permissions', []).hasAny(['health_mgmt'])) ||
        (getProfile().get('position', '').matches('.*장.*'))
      ) && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isHRManager() || isOwner(resource.data.authorUid));
    }

    match /client_errors/{errorId} {
      allow create: if true; // Allow logging even if not authenticated
      allow read: if isCoreAdmin();
    }

    // Default deny at the end
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
