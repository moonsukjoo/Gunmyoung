{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with RBAC roles: CEO(사장), DIRECTOR(소장), GENERAL_AFFAIRS(총무), GENERAL_MANAGER(실장), CLERK(서무), SAFETY_MANAGER(안전관리자), TEAM_LEADER(팀장), EMPLOYEE(일반사원)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "employeeId": { "type": "string", "description": "Employee ID (e.g., x66626)" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["CEO", "DIRECTOR", "GENERAL_AFFAIRS", "GENERAL_MANAGER", "CLERK", "SAFETY_MANAGER", "TEAM_LEADER", "EMPLOYEE"] 
        },
        "departmentId": { "type": "string" },
        "departmentName": { "type": "string" },
        "position": { "type": "string" },
        "jobRole": { "type": "string" },
        "workplace": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "annualLeaveBalance": { "type": "number", "description": "Remaining annual leave days" },
        "points": { "type": "number", "description": "Praise points (1 point = 5000 KRW)" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "resignedAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "hasCustomPin": { "type": "boolean", "description": "Whether the user has set a custom PIN/password" },
        "lastPinChange": { "type": "string", "format": "date-time" },
        "permissions": { "type": "array", "items": { "type": "string" }, "description": "Dynamic permissions: notice_mgmt, accident_mgmt, leave_mgmt, dept_mgmt, employee_mgmt, praise_coupon" },
        "safetyScore": { "type": "number", "description": "Safety performance score starting at 100" },
        "safetyScoreLastUpdate": { "type": "string", "format": "date-time" },
        "kudosCount": { "type": "number", "description": "Count of praises received from colleagues" },
        "monthlyKudosCount": { "type": "number", "description": "Kudos count for the current month" },
        "kudosMonth": { "type": "string", "description": "Current month string (YYYY-MM)" },
        "currentAltitude": { "type": "number", "description": "Current relative altitude in meters" },
        "altitudeUpdatedAt": { "type": "string", "format": "date-time" },
        "basePressure": { "type": "number", "description": "Baseline air pressure at ground level" },
        "ghostGuardEnabled": { "type": "boolean", "description": "Whether Ghost Guard (immobility detection) is active" },
        "lastMovementAt": { "type": "string", "format": "date-time" },
        "isImmobile": { "type": "boolean", "description": "Flag for workers detected as immobile" }
      },
      "required": ["uid", "email", "role", "displayName"]
    },
    "SafetyScoreLog": {
      "title": "Safety Score Log",
      "description": "Log of safety score adjustments",
      "type": "object",
      "properties": {
        "targetUid": { "type": "string" },
        "targetName": { "type": "string" },
        "adminUid": { "type": "string" },
        "adminName": { "type": "string" },
        "adminRole": { "type": "string" },
        "scoreDelta": { "type": "number" },
        "previousScore": { "type": "number" },
        "newScore": { "type": "number" },
        "reason": { "type": "string" },
        "type": { "type": "string", "enum": ["PENALTY", "REWARD"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["targetUid", "adminUid", "scoreDelta", "previousScore", "newScore", "type", "createdAt"]
    },
    "Praise": {
      "title": "Praise Feed",
      "description": "Short praise messages sent between workers for safety and help",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverUid": { "type": "string" },
        "receiverName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "receiverUid", "message", "createdAt"]
    },
    "PraiseComment": {
      "title": "Praise Comment",
      "description": "Comments on praise posts",
      "type": "object",
      "properties": {
        "praiseId": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["praiseId", "uid", "userName", "message", "createdAt"]
    },
    "PraiseCoupon": {
      "title": "Praise Coupon",
      "description": "Coupon given to employees for praise",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "receiverUid": { "type": "string" },
        "receiverName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "reason": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "receiverUid", "points", "createdAt"]
    },
    "WorkLog": {
      "title": "Daily Work Log",
      "description": "Log of work done by an employee for the day",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "departmentId": { "type": "string" },
        "departmentName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "userName", "date", "startTime", "endTime", "content", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance Log",
      "description": "Daily clock-in and clock-out logs",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PRESENT", "LATE", "ABSENT", "LEAVE"] },
        "healthStatus": { "type": "string", "enum": ["GOOD", "NORMAL", "BAD"] },
        "workHours": { "type": "number", "description": "Total hours including overtime" },
        "overtimeHours": { "type": "number", "description": "Overtime hours" },
        "memo": { "type": "string" }
      },
      "required": ["uid", "date", "clockIn"]
    },
    "AccidentCase": {
      "title": "Accident Case",
      "description": "Reported safety accidents and cases",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "type": { "type": "string", "enum": ["SAFE", "INCIDENT", "ACCIDENT", "OTHER"] },
        "measures": { "type": "string" },
        "reportedByUid": { "type": "string" },
        "reportedBy": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "location", "description", "severity", "type", "reportedByUid", "createdAt"]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Requests for vacation or leave",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["ANNUAL", "SICK", "SPECIAL", "OTHER"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "approvedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "startDate", "endDate", "status"]
    },
    "Notice": {
      "title": "Company Notice",
      "description": "Announcements for all or specific departments",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "targetDept": { "type": "string", "description": "ALL or specific department" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isImportant": { "type": "boolean" }
      },
      "required": ["title", "content", "authorUid", "createdAt"]
    },
    "Department": {
      "title": "Department",
      "description": "A department or team in the shipyard",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System and health check notifications",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["HEALTH_CHECK", "NOTICE", "SYSTEM", "LEAVE_REMINDER", "COUPON", "EMERGENCY"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" }
      },
      "required": ["uid", "title", "message", "type", "isRead", "createdAt"]
    },
    "LottoHistory": {
      "title": "Lotto History",
      "description": "History of generated lotto numbers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "lines": { 
          "type": "array", 
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "lines", "createdAt"]
    },
    "EmergencyLog": {
      "title": "Emergency SOS Log",
      "description": "Logs of emergency SOS requests sent by users",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "createdAt"]
    },
    "Training": {
      "title": "Training Module",
      "description": "Educational material and quiz for employees",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content" },
        "videoUrl": { "type": "string" },
        "targetJobRole": { "type": "string", "description": "Specific job role or empty for all" },
        "questions": { 
          "type": "array", 
          "items": { "$ref": "#/entities/QuizQuestion" } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "questions", "createdAt"]
    },
    "QuizQuestion": {
      "title": "Quiz Question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" }
      }
    },
    "TrainingResult": {
      "title": "Training Result",
      "description": "Employee's exam completion record",
      "type": "object",
      "properties": {
        "trainingId": { "type": "string" },
        "trainingTitle": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "isPassed": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trainingId", "uid", "score", "isPassed", "completedAt"]
    },
    "JobRole": {
      "title": "Job Role",
      "description": "Specific job role definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "RedemptionRequest": {
      "title": "Redemption Request",
      "description": "Request to redeem praise points for cash (현물 신청)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "pointsRequested": { "type": "number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "COMPLETED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" },
        "processedBy": { "type": "string" },
        "processedByName": { "type": "string" }
      },
      "required": ["uid", "userName", "pointsRequested", "amount", "status", "createdAt"]
    },
    "Banner": {
      "title": "Banner Setting",
      "description": "Customizable banner text on the dashboard",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["text", "updatedAt"]
    },
    "EvacuationStatus": {
      "title": "Emergency Evacuation Status",
      "description": "Global status for active emergency evacuations",
      "type": "object",
      "properties": {
        "isActive": { "type": "boolean" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "activatedByUid": { "type": "string" },
        "activatedByName": { "type": "string" },
        "reason": { "type": "string" },
        "totalWorkers": { "type": "number" },
        "confirmedCount": { "type": "number" }
      },
      "required": ["isActive", "activatedAt", "activatedByUid", "reason"]
    },
    "EvacuationCheckin": {
      "title": "Evacuation Check-in",
      "description": "User safety confirmation record during an evacuation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "departmentName": { "type": "string" },
        "confirmedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "confirmedAt"]
    },
    "Payslip": {
      "title": "Payslip",
      "description": "Monthly salary statement for an employee",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "employeeId": { "type": "string" },
        "userName": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "baseHours": { "type": "number" },
        "weeklyHolidayHours": { "type": "number" },
        "paidLeaveHours": { "type": "number" },
        "trainingHours": { "type": "number" },
        "otherHours": { "type": "number" },
        "monthlyLeaveHours": { "type": "number" },
        "holidayWorkHours": { "type": "number" },
        "overtimeHours": { "type": "number" },
        "totalHours": { "type": "number" },
        "hourlyRate": { "type": "number" },
        "baseSalary": { "type": "number" },
        "experienceAllowance": { "type": "number" },
        "otherAllowance": { "type": "number" },
        "annualLeaveAllowance": { "type": "number" },
        "mealAllowance": { "type": "number" },
        "extraAllowance": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "incomeTax": { "type": "number" },
        "localIncomeTax": { "type": "number" },
        "healthInsurance": { "type": "number" },
        "nationalPension": { "type": "number" },
        "employmentInsurance": { "type": "number" },
        "mealDeduction": { "type": "number" },
        "laundryDeduction": { "type": "number" },
        "totalDeductions": { "type": "number" },
        "netPay": { "type": "number" },
        "annualLeaveBaseDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "month", "totalEarnings", "netPay", "createdAt"]
    },
    "Beacon": {
      "title": "Bluetooth Beacon",
      "description": "BLE Beacon registered in the system for location tracking in enclosed spaces",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique beacon ID / Address" },
        "name": { "type": "string" },
        "submarineName": { "type": "string", "description": "Submarine or vessel name" },
        "location": { "type": "string", "description": "Specific location description inside (e.g., Entrance, Engine Room)" },
        "order": { "type": "number", "description": "Sequential order from entrance" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "ERROR"] },
        "batteryLevel": { "type": "number" },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "submarineName", "location", "order", "status", "createdAt"]
    },
    "BeaconLog": {
      "title": "Beacon Activity Log",
      "description": "Log of worker signal detections by beacons",
      "type": "object",
      "properties": {
        "beaconId": { "type": "string" },
        "beaconLocation": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "rssi": { "type": "number" },
        "detectedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["beaconId", "uid", "detectedAt"]
    },
    "LunchRequest": {
      "title": "Lunch Request",
      "description": "Individual request for lunch over a period",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" },
        "approvedByName": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "userName", "startDate", "endDate", "status", "createdAt"]
    },
    "GameSettings": {
      "title": "Game Probability Settings",
      "description": "Global settings for games like Roulette, Snail Race, and Fishing",
      "type": "object",
      "properties": {
        "rouletteProbabilities": { "type": "array", "items": { "type": "number" } },
        "snailProbabilities": { "type": "array", "items": { "type": "number" } },
        "fishingProbabilities": { "type": "array", "items": { "type": "number" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    },
    "SnackRequest": {
      "title": "Snack Request",
      "description": "Team-level request for snack delivery",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "departmentName": { "type": "string" },
        "quantity": { "type": "number" },
        "deliveryDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" },
        "approvedByName": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "userName", "quantity", "deliveryDate", "status", "createdAt"]
    },
    "WorkInstructionReport": {
      "title": "Work Instruction Report",
      "description": "Daily integrated work instruction and safety check report for a team",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "teamName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dayOfWeek": { "type": "string" },
        "supervisorName": { "type": "string" },
        "safetyManagerName": { "type": "string" },
        "tbmContent": { "type": "string" },
        "workerInstructions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "no": { "type": "number" },
              "workerUid": { "type": "string" },
              "workerName": { "type": "string" },
              "instruction": { "type": "string" },
              "startTime": { "type": "string" },
              "endTime": { "type": "string" },
              "hazardSubmitted": { "type": "boolean" },
              "healthStatus": { "type": "string", "enum": ["GOOD", "NORMAL", "BAD"] },
              "signBeforeUrl": { "type": "string" },
              "signAfterUrl": { "type": "string" }
            }
          }
        },
        "safetyChecks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "no": { "type": "number" },
                    "item": { "type": "string" },
                    "result": { "type": "string", "enum": ["O", "X", "N/A"] }
                  }
                }
              }
            }
          }
        },
        "hazardAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "no": { "type": "number" },
              "hazardFactor": { "type": "string" },
              "safetyMethod": { "type": "string" },
              "actionContent": { "type": "string" },
              "remarks": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByUid": { "type": "string" },
        "createdByName": { "type": "string" }
      },
      "required": ["teamId", "date", "status", "createdAt", "createdByUid"]
    }
  },
  "firestore": {
    "/workInstructionReports/{reportId}": {
      "schema": "WorkInstructionReport",
      "description": "Daily work instruction reports"
    },
    "/lunchRequests/{requestId}": {
      "schema": "LunchRequest",
      "description": "Individual lunch requests"
    },
    "/snackRequests/{requestId}": {
      "schema": "SnackRequest",
      "description": "Team snack requests"
    },
    "/beacons/{beaconId}": {
      "schema": "Beacon",
      "description": "Registered BLE beacons"
    },
    "/beaconLogs/{logId}": {
      "schema": "BeaconLog",
      "description": "Worker proximity logs"
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
